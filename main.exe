char choiceAB(const char *optA, const char *optB) {
    char c;

    printf("%s\n", optA);
    printf("%s\n", optB);
    printf("Choice (A/B): ");

    while (1) {
        scanf(" %c", &c);

        if (c == 'A' || c == 'a')
            return 'A';
        if (c == 'B' || c == 'b')
            return 'B';

        printf("Invalid choice. Please enter A or B: ");
    }
}
